# Copy this file to .env and fill in your credentials
# DO NOT commit the .env file to version control

# PostgreSQL connection string (Neon Serverless — pooled connection)
DATABASE_URL="postgresql://user:password@endpoint-pooler.neon.tech/dbname?sslmode=require"

# Direct connection to Neon (bypasses connection pooler, required for Prisma Migrate)
DIRECT_URL="postgresql://user:password@endpoint.neon.tech/dbname?sslmode=require"

# CORS origin for frontend dev server (default: http://localhost:5173)
CORS_ORIGIN="http://localhost:5173"

# Server port (default: 3000)
PORT=3000

# Log level (debug, info, warn, error). Default: info
LOG_LEVEL=info

# Azure Application Insights (optional — leave empty to disable)
# Get this from Azure Portal > Application Insights > Connection String
APPLICATIONINSIGHTS_CONNECTION_STRING=
